<div style="font-family:Helvetica, Arial, sans-serif; color:#333333;">
  <div style="font-size:18px; font-weight:600; margin-bottom:8px;">
    Your login code
  </div>

  <p style="margin:0 0 12px 0; font-size:14px; line-height:20px; color:#333;">
    Hello,
  </p>

  <p style="margin:0 0 12px 0; font-size:14px; line-height:20px; color:#555;">
    Use the code below to sign in to <strong>{{ appName }}</strong>. This code
    is valid for a short time and can be used only once.
  </p>

  <div style="margin:12px 0 18px 0; text-align:center;">
    <div style="display:inline-block; background:#f5f5f5; padding:14px 20px; border-radius:8px; border:1px solid #e0e0e0;">
      <span style="font-size:22px; letter-spacing:2px; font-weight:700; color:#111;">
        {{ token }}
      </span>
    </div>
  </div>

  <p style="margin:0 0 8px 0; font-size:12px; line-height:18px; color:#777;">
    If you didn't request this code, you can safely ignore this message.
  </p>

  <p style="margin:12px 0 0 0; font-size:12px; line-height:18px; color:#999;">
    &copy; {{ appName }}. All rights reserved.
  </p>
</div>
