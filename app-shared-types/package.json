{
    "name": "@hms/shared-types",
    "private": true,
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "require": "./dist/index.js",
            "default": "./dist/index.js"
        },
        "./hms": {
            "types": "./dist/hms/index.d.ts",
            "require": "./dist/hms/index.js",
            "default": "./dist/hms/index.js"
        },
        "./sg": {
            "types": "./dist/sg/index.d.ts",
            "require": "./dist/sg/index.js",
            "default": "./dist/sg/index.js"
        },
        "./package.json": "./package.json"
    },
    "files": [
        "dist"
    ],
    "dependencies": {
        "semver": "^7.7.3"
    },
    "devDependencies": {
        "@types/semver": "^7.7.1",
        "typescript": "~5.5.1",
        "ts-node": "^10.9.1",
        "ts-node-dev": "^2.0.0",
        "chokidar": "^3.5.3",
        "@types/node": "^20.8.4"
    },
    "scripts": {
        "build": "npm run generate:types-barrel && tsc -p tsconfig.prod.json",
        "build:watch": "npm run watch:types-barrel & tsc --watch",
        "build:watch:docker": "npm run watch:types-barrel & tsc --watch",
        "build:dev:watch": "ts-node-dev --respawn --transpile-only src/index.ts",
        "clean": "rimraf dist",
        "generate:types-barrel": "ts-node scripts/generate-exports.ts",
        "watch:types-barrel": "ts-node scripts/watch-types-barrel.ts"
    }
}